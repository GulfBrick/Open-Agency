# Open Agency — Environment Variables
# Copy to .env and fill in values

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Whop ─────────────────────────────────────────────────────
WHOP_API_KEY=
WHOP_WEBHOOK_SECRET=

# ── Gmail (Nodemailer) ───────────────────────────────────────
GMAIL_USER=openagency.n@gmail.com
GMAIL_APP_PASSWORD=

# ── Security ─────────────────────────────────────────────────
JWT_SECRET=
# Must be exactly 32 UTF-8 chars OR 64 hex chars
ENCRYPTION_KEY=

# ── API Auth ─────────────────────────────────────────────────
OPEN_AGENCY_API_KEY=oa_live_...

# ── Telegram ─────────────────────────────────────────────────
NIKITA_TELEGRAM_TOKEN=
HARRY_TELEGRAM_ID=

# ── ElevenLabs ───────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=https://oagencyconsulting.com
PORT=3001
